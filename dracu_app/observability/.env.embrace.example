# Template — copy to `.env.embrace` (gitignored, see ../.gitignore)
# and fill in with the values from dash.embrace.io > Settings.
#
# These are the same values that get baked into:
#   * android/app/src/main/embrace-config.json
#   * ios/Runner/Embrace-Info.plist
#
# Keeping them mirrored here lets CI source one .env file and
# materialise both per-platform config files without duplicating
# secrets in the GitHub Actions workflow.
EMBRACE_APP_ID=REPLACE_ME_12_CHAR_HEX
EMBRACE_API_TOKEN=REPLACE_ME_32_CHAR_HEX
